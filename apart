    }

    .price-soft {
      font-size: 18px;
      color: var(--text-soft);
      font-weight: 700;
    }

    .contact-inline-wrap,
    .cta-actions,
    .footer-links {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .contact-inline-wrap {
      margin: 4px 0 18px;
    }

    .contact-inline,
    .btn,
    .sticky-btn {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 48px;
      padding: 0 20px;
      border-radius: 999px;
      font-size: 15px;
      font-weight: 800;
      white-space: nowrap;
      border: 1px solid rgba(255,255,255,0.35);
      background: var(--glass-medium);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      color: var(--primary-dark);
      box-shadow: 0 12px 28px rgba(15,23,42,0.10);
      overflow: hidden;
      isolation: isolate;
      transition: transform .25s ease, box-shadow .25s ease, background .25s ease, border-color .25s ease, filter .25s ease;
    }

    .contact-inline::before,
    .btn::before,
    .sticky-btn::before {
      content: "";
      position: absolute;
      inset: 1px;
      border-radius: inherit;
      background: linear-gradient(180deg, rgba(255,255,255,0.38), rgba(255,255,255,0.08));
      opacity: .7;
      pointer-events: none;
      z-index: 0;
    }

    .contact-inline::after,
    .btn::after,
    .sticky-btn::after {
      content: "";
      position: absolute;
      top: -140%;
      left: -30%;
      width: 55%;
      height: 320%;
      transform: rotate(24deg);
      background: linear-gradient(180deg, rgba(255,255,255,0), rgba(255,255,255,0.42), rgba(255,255,255,0));
      opacity: 0;
      pointer-events: none;
      z-index: 1;
      transition: opacity .25s ease, transform .55s ease;
    }

    .contact-inline > *,
    .btn > *,
    .sticky-btn > * { position: relative; z-index: 2; }

    .contact-inline:first-child,
    .btn-main {
      background: linear-gradient(135deg, rgba(226,135,67,0.78), rgba(200,116,47,0.88));
      color: #fff;
      border: 1px solid rgba(255,255,255,0.24);
      box-shadow: 0 14px 34px rgba(200,116,47,0.25), 0 0 0 1px rgba(255,255,255,0.10) inset;
    }

    .contact-inline:last-child,
    .btn-light {
      background: var(--glass-light);
      color: var(--primary-dark);
      border: 1px solid rgba(255,255,255,0.35);
      box-shadow: 0 8px 22px rgba(15,23,42,0.06), 0 0 0 1px rgba(255,255,255,0.10) inset;
    }

    .contact-inline:hover,
    .btn:hover,
    .sticky-btn:hover {
      transform: translateY(-3px) scale(1.02);
      box-shadow: 0 20px 44px rgba(15,23,42,0.12), 0 0 24px rgba(255,255,255,0.14);
      filter: saturate(1.04);
    }

    .contact-inline:hover::after,
    .btn:hover::after,
    .sticky-btn:hover::after {
      opacity: 1;
      transform: translateX(150%) rotate(24deg);
    }

    .btn-main:hover {
      box-shadow: 0 22px 48px rgba(200,116,47,0.35), 0 0 30px rgba(226,135,67,0.20);
      background: linear-gradient(135deg, rgba(226,135,67,0.95), rgba(200,116,47,1));
    }

    .contact-inline:active,
    .btn:active,
    .sticky-btn:active { transform: translateY(-1px) scale(0.99); }

    .kpi-row {
      display: grid;
      grid-template-columns: repeat(3, minmax(0,1fr));
      gap: 14px;
      margin: 0 0 22px;
    }

    .kpi {
      padding: 18px 18px 16px;
      border-radius: 18px;
      border: 1px solid rgba(226,135,67,0.18);
      background: linear-gradient(180deg, #fff 0%, #fff7ef 100%);
      box-shadow: 0 8px 24px rgba(0,0,0,.04);
      text-align: center;
      transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease;
    }

    .kpi:hover {
      transform: translateY(-4px);
      box-shadow: 0 18px 34px rgba(226,135,67,0.12);
      border-color: rgba(226,135,67,0.34);
    }

    .kpi strong {
      display: block;
      font-size: 18px;
      margin-bottom: 6px;
      color: var(--primary-dark);
    }

    .kpi .value {
      font-weight: 900;
      font-size: clamp(18px, 2.4vw, 24px);
      color: var(--accent-dark);
      letter-spacing: -0.02em;
      text-wrap: balance;
    }

    .lead {
      width: 100%;
      max-width: 100%;
      font-size: 16px;
      text-wrap: pretty;
      text-align: justify;
      text-justify: inter-word;
    }

    .params-title {
      margin: 34px 0 10px;
      font-size: 24px;
      color: var(--primary-dark);
    }

    .params-accent {
      width: 68px;
      height: 2px;
      background: linear-gradient(90deg, var(--accent), transparent);
      margin-bottom: 14px;
      border-radius: 999px;
    }

    .params {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 18px;
      align-items: center;
    }

    .param {
      display: inline-flex;
      align-items: baseline;
      gap: 6px;
      padding: 2px 0;
      font-size: 15px;
      font-weight: 600;
      color: var(--text);
    }

    .param strong {
      font-size: 11px;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .08em;
      margin-right: 2px;
    }

    .why-grid,
    .contact-form-grid,
    .sticky-contact .wrap {
      display: grid;
      gap: 22px;
    }

    .why-grid { grid-template-columns: repeat(3, minmax(0,1fr)); margin-top: 18px; }

    .why-item {
      padding: 22px;
      border-radius: 20px;
      border: 1px solid var(--line);
      background: #fff;
      box-shadow: var(--shadow-soft);
      transition: transform .28s ease, box-shadow .28s ease;
    }

    .why-item:hover {
      transform: translateY(-4px);
      box-shadow: 0 18px 36px rgba(15,23,42,0.08);
    }

    .why-item strong {
      display: block;
      margin-bottom: 8px;
      font-size: 17px;
      color: var(--primary-dark);
    }

    .contact-box { text-align: center; background: var(--glass-strong); }
    .contact-links { display: grid; gap: 12px; margin: 20px 0 18px; }
    .contact-links a { font-weight: 700; color: #6b7280; font-size: 18px; }
    .contact-form { display: grid; gap: 14px; text-align: left; margin-top: 24px; }
    .contact-form-grid { grid-template-columns: 1fr 1fr; gap: 14px; }

    .contact-form input,
    .contact-form textarea {
      width: 100%;
      padding: 15px 16px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.28);
      background: var(--glass-strong);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      color: var(--text);
      outline: none;
      font-family: inherit;
      font-size: 16px;
      transition: border-color .22s ease, box-shadow .22s ease, transform .22s ease;
      appearance: none;
      -webkit-appearance: none;
    }

    .contact-form textarea { min-height: 130px; resize: vertical; }

    .contact-form input:focus,
    .contact-form textarea:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 4px rgba(41,108,118,0.12);
      transform: translateY(-1px);
    }

    .cta-box {
      text-align: center;
      background: linear-gradient(180deg, #ffffff 0%, var(--primary-pale) 100%);
    }

    .cta-actions { justify-content: center; margin-top: 18px; }

