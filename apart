  <style>
    :root {
      --primary: #5ec6e8;
      --primary-dark: #1f6f85;
      --primary-pale: #f3fbfe;
      --accent: #e28743;
      --accent-dark: #c8742f;
      --text: #1f2933;
      --text-soft: #5f6b76;
      --muted: #97a3ad;
      --line: rgba(94,198,232,0.18);
      --shadow-soft: 0 8px 20px rgba(15, 23, 42, 0.04);
      --shadow-lux: 0 18px 40px rgba(15, 23, 42, 0.06);
      --shadow: 0 18px 48px rgba(15, 23, 42, 0.08);
      --radius: 12px;
      --container: 1280px;
      --glass-light: rgba(255, 255, 255, 0.55);
      --glass-medium: rgba(255, 255, 255, 0.70);
      --glass-strong: rgba(255, 255, 255, 0.88);
      --maxw: 1200px;
      --white: #ffffff;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Inter, Arial, sans-serif;
      color: var(--text);
      background: linear-gradient(180deg, #ffffff 0%, #f7fcfe 60%, #ffffff 100%);
      line-height: 1.72;
      overflow-x: hidden;
    }

    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    h1, h2, h3 { margin: 0 0 14px; line-height: 1.08; }
    p {
