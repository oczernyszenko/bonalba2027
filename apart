    .prev { left: 16px; }
    .next { right: 16px; }
    .prev-plan { left: 8px; }
    .next-plan { right: 8px; }

    .plans-wrap {
      position: relative;
      padding: 16px 56px 20px;
      background: transparent;
    }

    .plans-label {
      margin: 0 0 10px;
      font-size: 11px;
      font-weight: 800;
      color: var(--primary-dark);
      text-transform: uppercase;
      letter-spacing: .12em;
    }

    .prev-plan, .next-plan { top: 61%; font-size: 24px; }
    .plans-viewport { overflow: hidden; }

    .plans-track {
      display: flex;
      gap: 12px;
      transition: transform .35s ease;
      will-change: transform;
    }

    .plans-track img {
      flex: 0 0 calc((100% - 24px) / 3);
