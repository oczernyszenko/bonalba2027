      height: 46px;
      border-radius: 14px;
      font-size: 28px;
      line-height: 1;
      cursor: pointer;
      z-index: 3;
      opacity: 0;
      pointer-events: none;
      transition: opacity .25s ease, color .25s ease, transform .25s ease, background .25s ease, box-shadow .25s ease;
      box-shadow: 0 10px 24px rgba(15,23,42,0.12);
    }

    .gallery-main:hover .nav-btn,
    .plans-wrap:hover .nav-btn,
    .gallery-main:focus-within .nav-btn,
    .plans-wrap:focus-within .nav-btn {
      opacity: 1;
      pointer-events: auto;
      color: rgba(255,255,255,0.92);
    }

    .nav-btn:hover {
      background: rgba(41,108,118,0.78);
      color: #fff;
      transform: translateY(-50%) scale(1.06);
      box-shadow: 0 16px 34px rgba(15,23,42,0.16);
