  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const contactForm = document.getElementById('contact-form');
      if (contactForm) {
        contactForm.addEventListener('submit', (event) => {
          event.preventDefault();
          const formData = new FormData(contactForm);
          const name = formData.get('name') || '';
          const phone = formData.get('phone') || '';
          const email = formData.get('email') || '';
          const message = formData.get('message') || '';
          const text = `Nowe zapytanie ze strony Nowe inwestycje:\n\nImię: ${name}\nTelefon: ${phone}\nEmail: ${email}\n\nWiadomość:\n${message}`;
          const url = `https://wa.me/34604158859?text=${encodeURIComponent(text)}`;
          const opened = window.open(url, '_blank', 'noopener');
          if (!opened) window.location.href = url;
        });
      }

      const main = document.getElementById('mainImage');
      const lightbox = document.getElementById('lightbox');
      const lightboxImage = document.getElementById('lightboxImage');
      const nextBtn = document.querySelector('.next');
      const prevBtn = document.querySelector('.prev');
      const nextPlanBtn = document.querySelector('.next-plan');
      const prevPlanBtn = document.querySelector('.prev-plan');
      const planTrack = document.getElementById('planTrack');
      const planImages = Array.from(document.querySelectorAll('.plans-track img'));
      const heroCard = document.querySelector('.hero-card');

      const galleryImages = [
        'bonalba-golf-hills-main.jpg',
        'bonalba-golf-hills-exterior-1.jpg',
        'bonalba-golf-hills-exterior-2.jpg',
        'bonalba-golf-hills-interior-1.jpg',
        'bonalba-golf-hills-interior-2.jpg',
        'bonalba-golf-hills-bedroom.jpg'
      ];

      if (!main || !nextBtn || !prevBtn || !nextPlanBtn || !prevPlanBtn || !planTrack || !planImages.length) return;

      let mainIndex = 0;
      let startX = 0;
      let planIndex = 0;
      let planStart = 0;
      const visiblePlans = 3;
      let autoplay = null;
      let autoplayStopped = false;

      function showMain() {
        main.src = galleryImages[mainIndex];
      }

      function stopAutoplay() {
        if (autoplay) {
          clearInterval(autoplay);
          autoplay = null;
        }
      }

      function startAutoplay() {
        stopAutoplay();
        if (autoplayStopped) return;
        autoplay = window.setInterval(() => {
          mainIndex = (mainIndex + 1) % galleryImages.length;
          showMain();
        }, 3800);
      }

      function updatePlans() {
        const cardWidth = planImages[0].getBoundingClientRect().width;
        const styles = window.getComputedStyle(planTrack);
        const gap = parseFloat(styles.columnGap || styles.gap || '12') || 12;
        const maxIndex = Math.max(planImages.length - visiblePlans, 0);
        if (planIndex > maxIndex) planIndex = maxIndex;
        planTrack.style.transform = `translateX(-${planIndex * (cardWidth + gap)}px)`;
      }

      nextBtn.addEventListener('click', () => {
        autoplayStopped = true;
        stopAutoplay();
        mainIndex = (mainIndex + 1) % galleryImages.length;
        showMain();
      });

      prevBtn.addEventListener('click', () => {
        autoplayStopped = true;
        stopAutoplay();
        mainIndex = (mainIndex - 1 + galleryImages.length) % galleryImages.length;
        showMain();
      });

      main.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
      main.addEventListener('touchend', (e) => {
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 40) {
          autoplayStopped = true;
          stopAutoplay();
          mainIndex = dx < 0 ? (mainIndex + 1) % galleryImages.length : (mainIndex - 1 + galleryImages.length) % galleryImages.length;
          showMain();
        }
      }, { passive: true });

      main.addEventListener('click', () => {
        lightboxImage.src = main.src;
        lightbox.classList.add('open');
        lightbox.setAttribute('aria-hidden', 'false');
      });

      lightbox.addEventListener('click', () => {
        lightbox.classList.remove('open');
        lightbox.setAttribute('aria-hidden', 'true');
      });

      nextPlanBtn.addEventListener('click', () => {
        planIndex = Math.min(planIndex + visiblePlans, Math.max(planImages.length - visiblePlans, 0));
        updatePlans();
      });

      prevPlanBtn.addEventListener('click', () => {
        planIndex = Math.max(planIndex - visiblePlans, 0);
        updatePlans();
      });

      planTrack.addEventListener('touchstart', (e) => { planStart = e.touches[0].clientX; }, { passive: true });
      planTrack.addEventListener('touchend', (e) => {
        const dx = e.changedTouches[0].clientX - planStart;
        if (Math.abs(dx) > 40) {
          planIndex = dx < 0 ? Math.min(planIndex + visiblePlans, Math.max(planImages.length - visiblePlans, 0)) : Math.max(planIndex - visiblePlans, 0);
          updatePlans();
        }
      }, { passive: true });

      planImages.forEach((img) => {
        img.addEventListener('mouseenter', () => {
          main.src = img.src;
        });
        img.addEventListener('mouseleave', showMain);
        img.addEventListener('click', () => {
          lightboxImage.src = img.src;
          lightbox.classList.add('open');
          lightbox.setAttribute('aria-hidden', 'false');
        });
      });

      heroCard?.addEventListener('mouseenter', stopAutoplay);
      heroCard?.addEventListener('mouseleave', startAutoplay);
      window.addEventListener('resize', updatePlans);

      showMain();
      updatePlans();
      startAutoplay();
    });
  </script>

