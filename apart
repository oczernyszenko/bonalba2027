      grid-template-columns: auto 1fr;
      align-items: center;
      gap: 24px;
      min-height: 86px;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-size: 18px;
      font-weight: 900;
      letter-spacing: -.03em;
      color: var(--primary-dark);
    }

    .brand::before {
      content: "";
